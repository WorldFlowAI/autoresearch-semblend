\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces \textbf  {SemBlend KV donor injection} TTFT speedup across two model architectures on \textbf  {A10G} GPU (24\,GiB). Measured via vLLM~v0.14.1 with \texttt  {SemBlendConnectorV1} wrapping LMCache, with RoPE delta correction enabled. Per-length pod restarts eliminate cross-length contamination. Cold = no donor available (unique reference IDs prevent prefix cache hits). SemBlend TTFT is near-constant (${\sim }500$--$830$\,ms) as prompt length grows, since KV load from CPU offload dominates. $n{=}5$ per length per model. In controlled single-donor scenarios with matched document variations.}}{9}{table.caption.33}\protected@file@percent }
\newlabel{tab:results-kv}{{4}{9}{\textbf {SemBlend KV donor injection} TTFT speedup across two model architectures on \textbf {A10G} GPU (24\,GiB). Measured via vLLM~v0.14.1 with \texttt {SemBlendConnectorV1} wrapping LMCache, with RoPE delta correction enabled. Per-length pod restarts eliminate cross-length contamination. Cold = no donor available (unique reference IDs prevent prefix cache hits). SemBlend TTFT is near-constant (${\sim }500$--$830$\,ms) as prompt length grows, since KV load from CPU offload dominates. $n{=}5$ per length per model. In controlled single-donor scenarios with matched document variations}{table.caption.33}{}}
