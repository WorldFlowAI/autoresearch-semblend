\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Variation sensitivity.} \textit  {Left:} PPL ratio stays at $1.000\pm 0.001$ for all 7 variation types (cosine 1.0 to 0.20), confirming SemBlend's quality floor guarantee. The red star marks the FM2 semantic-staleness outlier (PPL=1.27) observed in the threshold sweep (\S  \ref {sec:analysis:threshold}); no such outlier appears in the variation sensitivity data. \textit  {Right:} LMCache hit rates are non-monotonic---block-hash matching, not cosine similarity, determines hit probability. CNN/DailyMail 8K; Qwen2.5-7B-AWQ shown (LLaMA-3.1-8B-AWQ replicates: PPL=$1.000{\pm }0.001$ across all types), $n{=}8$ per type.}}{18}{figure.caption.68}\protected@file@percent }
\newlabel{fig:variation-sensitivity}{{2}{18}{\textbf {Variation sensitivity.} \textit {Left:} PPL ratio stays at $1.000\pm 0.001$ for all 7 variation types (cosine 1.0 to 0.20), confirming SemBlend's quality floor guarantee. The red star marks the FM2 semantic-staleness outlier (PPL=1.27) observed in the threshold sweep (\S \ref {sec:analysis:threshold}); no such outlier appears in the variation sensitivity data. \textit {Right:} LMCache hit rates are non-monotonic---block-hash matching, not cosine similarity, determines hit probability. CNN/DailyMail 8K; Qwen2.5-7B-AWQ shown (LLaMA-3.1-8B-AWQ replicates: PPL=$1.000{\pm }0.001$ across all types), $n{=}8$ per type}{figure.caption.68}{}}
