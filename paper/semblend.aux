\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Taxonomy of KV cache reuse systems. \textsc  {SemBlend}\xspace  combines in-process semantic donor discovery, layer-granular recomputation modeling, exact RoPE delta correction, and two-tier scaling. \textsc  {SemBlend}\xspace  is the first to solve the RoPE position encoding challenge (\S  \ref {sec:rope-correction}), enabling non-contiguous KV reuse on modern transformers. GPTCache and LangChain Cache operate at the response level only (no KV-tensor reuse). $O(N)$/$O(\log N)$ = local brute-force / GPU-accelerated ANN.}}{3}{table.caption.4}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{tab:taxonomy}{{1}{3}{Taxonomy of KV cache reuse systems. \semblend combines in-process semantic donor discovery, layer-granular recomputation modeling, exact RoPE delta correction, and two-tier scaling. \semblend is the first to solve the RoPE position encoding challenge (\S \ref {sec:rope-correction}), enabling non-contiguous KV reuse on modern transformers. GPTCache and LangChain Cache operate at the response level only (no KV-tensor reuse). $O(N)$/$O(\log N)$ = local brute-force / GPU-accelerated ANN}{table.caption.4}{}}
